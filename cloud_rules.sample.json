{
  "configVersion": "2026-03-21",
  "global": {
    "keywords": [
      "dicom",
      "download",
      "baixar",
      "zip",
      "imagens",
      "export",
      "estudo"
    ]
  },
  "vendors": [
    {
      "id": "aurora-pacs",
      "name": "Aurora PACS",
      "priority": 140,
      "detect": {
        "hostnameContains": [
          "pacs.cedirp.com.br"
        ],
        "pathContains": [
          "/resource/"
        ],
        "textContainsAny": [
          "Baixar",
          "Galeria",
          "Informações do Paciente",
          "MAMOGRAFIA DIGITAL BILATERAL"
        ],
        "selectorExists": [
          ".downloadToolsItem",
          "a[download='exam_dicom.zip']",
          ".styles__DropDownToolsWrapper-sc-152ee91-2"
        ],
        "scriptSrcContains": [
          "main."
        ]
      },
      "actions": [
        {
          "type": "pulse_halo_selector",
          "selector": ".downloadToolsItem, a[download='exam_dicom.zip']",
          "durationMs": 10000
        }
      ],
      "manualHint": "Link explicito de download DICOM encontrado. O download pode ser iniciado automaticamente."
    },
    {
      "id": "pixeonkorus",
      "name": "Pixeon Korus",
      "priority": 120,
      "detect": {
        "hostnameContains": [
          "pixeonkorus",
          "pixeon"
        ],
        "pathContains": [
          "/Paciente.aspx"
        ],
        "textContainsAny": [
          "Resultados On-Line",
          "Exame de Imagem",
          "PACIENTE:"
        ],
        "selectorExists": [
          "img[alt='Pixeon']",
          "#ctl00_ContentPlaceHolderConteudo_GV_Pacientes",
          "input[title='Exame de Imagem']"
        ],
        "scriptSrcContains": []
      },
      "actions": [
        {
          "type": "pulse_halo_selector",
          "selector": "input[title='Exame de Imagem']",
          "durationMs": 10000
        }
      ],
      "manualHint": "Tabela de exames encontrada. Use o botao de imagem destacado em vermelho."
    },
    {
      "id": "generic-download",
      "name": "Generic Download Portal",
      "priority": 40,
      "detect": {
        "hostnameContains": [
          "localhost",
          "127.0.0.1"
        ],
        "pathContains": [
          "/portal",
          "/viewer"
        ],
        "textContainsAny": [
          "download",
          "baixar",
          "dicom",
          "exportar"
        ],
        "selectorExists": [
          "#downloadExam",
          "button[data-test='download-exam']",
          "a[download]"
        ],
        "scriptSrcContains": []
      },
      "actions": [
        {
          "type": "highlight_selector",
          "selector": "#downloadExam"
        },
        {
          "type": "click_selector",
          "selector": "#downloadExam",
          "waitMs": 1200
        }
      ],
      "manualHint": "Portal generico com botao de download identificado."
    },
    {
      "id": "animate",
      "name": "Animate",
      "priority": 100,
      "detect": {
        "hostnameContains": [
          "animate"
        ],
        "pathContains": [
          "/viewer",
          "/exam"
        ],
        "textContainsAny": [
          "animate",
          "dicom"
        ],
        "selectorExists": [
          "#btnDownloadExam"
        ],
        "scriptSrcContains": [
          "animate"
        ]
      },
      "actions": [
        {
          "type": "click_selector",
          "selector": "#btnDownloadExam",
          "waitMs": 1000
        }
      ],
      "manualHint": "Fornecedor Animate detectado."
    },
    {
      "id": "manual-review",
      "name": "Manual Review Portal",
      "priority": 15,
      "detect": {
        "hostnameContains": [],
        "pathContains": [],
        "textContainsAny": [
          "imagens",
          "download do exame",
          "exportar estudo"
        ],
        "selectorExists": [],
        "scriptSrcContains": []
      },
      "actions": [
        {
          "type": "manual_only",
          "message": "Fornecedor parcialmente reconhecido. Revise o menu de exportacao."
        }
      ],
      "manualHint": "Ha sinais de portal conhecido, mas a acao ainda depende de revisao manual."
    }
  ]
}
